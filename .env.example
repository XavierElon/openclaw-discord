DISCORD_TOKEN=
GATEWAY_TOKEN=
# Compose + OpenClaw image expect these names (same values as above).
DISCORD_BOT_TOKEN=${DISCORD_TOKEN}
OPENCLAW_GATEWAY_TOKEN=${GATEWAY_TOKEN}
GEMINI_API_KEY=

OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
OPENCLAW_TZ=America/Los_Angeles
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_GATEWAY_BIND=lan

# Use your existing `openclaw setup` data (default ./data/config was empty → gateway crash loop).
OPENCLAW_CONFIG_DIR=/Users/<>/.openclaw
OPENCLAW_WORKSPACE_DIR=/Users/<>/.openclaw/workspace
# Optional: macOS path for bind-mount so persisted agent/cron paths (/Users/...) work in Linux (defaults to shell $HOME when unset).
# OPENCLAW_HOST_HOME=/Users/xavierelon
# Optional: where nvm lives on the host (skills load from ~/.nvm/.../openclaw/skills inside the container).
# OPENCLAW_NVM_DIR=/Users/xavierelon/.nvm

USER_ID=
GUILD_ID=
CHANNEL_ID=

